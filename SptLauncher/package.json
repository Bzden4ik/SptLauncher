{
  "name": "spt-launcher",
  "version": "1.1.3",
  "description": "SPT Launcher",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.spt.launcher",
    "productName": "SPT Launcher",
    "win": { "target": "nsis", "icon": "resources/icon.ico" },
    "directories": { "output": "dist" },
    "extraResources": [
      { "from": "resources/Convergence.mp3", "to": "Convergence.mp3" }
    ]
  }
}
